{
  "name": "fernando-tecnico-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:full": "npm run optimize:images && npm run update:colors && npm run generate:images && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "generate:images": "node scripts/generate-images.js",
    "optimize:images": "node scripts/optimize-images.js",
    "update:colors": "node scripts/update-colors.js",
    "remove:comments": "node scripts/remove-comments.js",
    "remove:console": "node scripts/remove-console.js",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "9.15.0",
    "eslint-config-next": "15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "puppeteer": "^25.3.0",
    "sharp": "^0.35.3",
    "typescript": "^5.9.0"
  }
}
